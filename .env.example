## .env.example - Copy to .env & fill values!
# NEVER commit .env (gitignore protects it)

# Required: xAI/Grok API (console.x.ai)
XAI_API_KEY=sk-your-key-here

# Optional: Model (grok-beta default)
GROK_MODEL=grok-beta

# Optional: Web search (serper.dev free tier)
SERPER_API_KEY=serper-your-key-optional