# xAI / Grok API Keys (console.x.ai)
XAI_API_KEY=sk-proj-your_xai_api_key_here
XAI_MANAGEMENT_API_KEY=your_xai_management_api_key_here  # optional, for advanced features

# Web Search (serper.dev - free tier available)
SERPER_API_KEY=your_serper_api_key_here

# Voice Features (optional)
VOICE_TESTING_KEY=your_voice_testing_key_here

# Jira / Atlassian (optional, for jira tools)
JIRA_API_KEY=your_jira_personal_access_token_here

# Default Model
GROK_MODEL=grok-beta

# Uncomment/add more as needed